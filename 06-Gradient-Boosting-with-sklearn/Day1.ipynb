    "print(\"- Iterative formula\")\n",
    "print(\"- Shrinkage (Learning Rate)\")\n",
    "print(\"- Boosting vs Bagging\")\n",
    "print(\"- GradientBoostingRegressor in sklearn\")\n",
    "print(\"=\"*40)\"\n",
    "print(\"\\nNext: Day 2 - Gradient Boosting Classification\")"
   }
