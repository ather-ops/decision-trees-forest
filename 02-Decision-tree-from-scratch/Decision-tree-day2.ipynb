   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Binary vs Non-Binary Conditions - Hands On"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Binary Condition\n",
    "def binary_condition(x):\n",
    "    if x >= 3:\n",
    "        return \"Yes\"\n",
    "    else:\n",
    "        return \"No\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Non-Binary Condition\n",
    "def non_binary_condition(color):\n",
    "    if color == \"red\":\n",
    "        return \"Class A\"\n",
    "    elif color == \"blue\":\n",
    "        return \"Class B\"\n",
    "    else:\n",
    "        return \"Class C\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Binary Condition Examples:\")\n",
    "print(\"=\"*30)\n",
    "values = [1, 2, 3, 4, 5]\n",
    "for v in values:\n",
    "    print(f\"Input: {v} -> {binary_condition(v)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\\nNon-Binary Condition Examples:\")\n",
    "print(\"=\"*30)\n",
    "colors = [\"red\", \"blue\", \"green\", \"yellow\", \"red\"]\n",
    "for c in colors:\n",
    "    print(f\"Input: {c} -> {non_binary_condition(c)}\")"
   ]
  },
